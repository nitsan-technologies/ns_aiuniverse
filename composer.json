{
    "name": "nitsan/ns-aiuniverse",
    "type": "typo3-cms-extension",
    "description": "AI Universe is the shared AI foundation layer for TYPO3 extensions. It centralizes AI provider communication, model selection, request handling, statistics preparation, and utility functions so other extensions can build AI features faster and with consistent behavior.",
    "homepage": "https://t3planet.de",
    "authors": [
        {
            "name": "Team T3Planet",
            "role": "Developer",
            "homepage": "https://t3planet.de",
            "email": "support@t3planet.de"
        }
    ],
    "license": "GPL-2.0-or-later",
    "keywords": [
        "TYPO3",
        "AI",
        "OpenAI",
        "Gemini",
        "Claude",
        "Azure",
        "DeepSeek",
        "xAI",
        "Mistral",
        "Base Extension"
    ],
    "support": {
        "issues": "https://t3planet.de/support"
    },
    "require": {
        "typo3/cms-core": "^11 || ^12 || ^13",
        "php": "^7.4 || ^8",
        "erusev/parsedown": "^1.7"
    },
    "autoload": {
        "psr-4": {
            "NITSAN\\NsAiUniverse\\": "Classes"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "NITSAN\\NsAiUniverse\\Tests\\": "Tests/"
        }
    },
    "replace": {
        "typo3-ter/ns-aiuniverse": "self.version"
    },
    "config": {
        "vendor-dir": ".Build/vendor",
        "bin-dir": ".Build/bin",
        "sort-packages": true,
        "allow-plugins": {
            "composer/package-versions-deprecated": true,
            "typo3/class-alias-loader": true,
            "typo3/cms-composer-installers": true
        }
    },
    "extra": {
        "typo3/cms": {
            "web-dir": ".Build/public",
            "extension-key": "ns_aiuniverse"
        }
    },
    "scripts": {
        "cs:check": ".Build/bin/php-cs-fixer fix --dry-run --diff",
        "doc-watch": "docker run --rm -it --pull always -v \"$(pwd)/Documentation:/project/Documentation\" -v \"$(pwd)/Documentation-GENERATED-temp:/project/Documentation-GENERATED-temp\" -p 1337:1337 ghcr.io/typo3-documentation/render-guides:latest --config=Documentation --watch",
        "stan": ".Build/bin/phpstan analyse --memory-limit=512M",
        "test": ".Build/bin/phpunit -c phpunit.xml.dist"
    },
    "scripts-descriptions": {
        "cs:check": "Run PHP-CS-Fixer in dry-run mode",
        "doc-watch": "Render documentation with watcher",
        "stan": "Run PHPStan static analysis",
        "test": "Run PHPUnit test suite"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.94",
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^13.0"
    }
}
